      "link": null,
      "locked": false,
      "text": "Current Infrastructure:\n\n\nEC2 instances running the application\n\nS3 bucket storing user data and application assets\n\nRDS database for user information\n\nCloudWatch for monitoring\n\nSeveral development and production environments",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Current Infrastructure:\n\n\nEC2 instances running the application\n\nS3 bucket storing user data and application assets\n\nRDS database for user information\n\nCloudWatch for monitoring\n\nSeveral development and production environments",
      "autoResize": true,
      "lineHeight": 1.25
